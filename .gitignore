# Dev convenience: a nested lab workspace at the repo root. Generated by
# `LABAGENTS_DEV=1 deploy/setup-workspace.sh RamanLabWorkspace`. Contains only
# lab-local config and run records, never product source.
RamanLabWorkspace/

# Dev convenience: a nested lab workspace checked out in the repo root.
# Generated by deploy/setup-workspace.sh; guardrail is disabled for it, so it
# must never be used as a real lab deployment.
/RamanLabWorkspace/

