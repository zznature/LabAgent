{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"lib": ["ES2024"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"noImplicitOverride": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2024",
		"types": ["node", "vitest/globals"]
	},
	"include": ["src/extensions/**/*.ts", "deploy/**/*.mjs"]
}
